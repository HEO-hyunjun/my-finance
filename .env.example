# ──────────────────────────────────────────────
# Database (MySQL)
# ──────────────────────────────────────────────
# docker-compose에서 DB 컨테이너와 DATABASE_URL 구성에 사용됩니다.
# 프로덕션 환경에서는 반드시 강력한 비밀번호로 변경하세요.
MYSQL_USER=myfinance
MYSQL_PASSWORD=myfinance
MYSQL_DB=myfinance
MYSQL_ROOT_PASSWORD=rootpassword

# ──────────────────────────────────────────────
# 로컬 개발 접속 URL (docker compose 외부에서 실행 시)
# ──────────────────────────────────────────────
# 로컬에서 uvicorn 직접 실행 시 사용됩니다.
# docker compose 실행 시에는 docker-compose.yml의 environment가 우선합니다.
DATABASE_URL=mysql+asyncmy://myfinance:myfinance@localhost:3307/myfinance?charset=utf8mb4
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# 보안 (JWT / 암호화)
# ──────────────────────────────────────────────
# 프로덕션 환경에서는 반드시 안전한 랜덤 값으로 변경하세요.
# 생성 예시: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me

# ──────────────────────────────────────────────
# 검색 프로바이더 설정
# ──────────────────────────────────────────────
# 뉴스/웹 검색에 사용할 프로바이더 선택 (금융 시세는 항상 yfinance 사용)
# "tavily"    = Tavily (기본값, 무료 월 1,000 크레딧)
# "serpapi"   = SerpAPI (유료 구독)
# "firecrawl" = Firecrawl (셀프호스트 또는 클라우드)
SEARCH_PROVIDER=tavily

# Tavily (https://tavily.com)
TAVILY_API_KEY=

# SerpAPI (https://serpapi.com)
SERPAPI_KEY=

# Firecrawl (https://firecrawl.dev)
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=

# Fernet encryption key (개인 API 키 암호화 시 사용)
# 반드시 32바이트 url-safe base64 문자열(44자)이어야 합니다.
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 주의: 키를 바꾸면 기존에 저장된 암호화 데이터는 복호화 불가
ENCRYPTION_KEY=

# ──────────────────────────────────────────────
# LLM 설정 (LiteLLM 기반)
# ──────────────────────────────────────────────
# LiteLLM을 통해 다양한 LLM 프로바이더를 지원합니다.
# 서비스별로 다른 프로바이더/모델을 혼합 사용할 수 있습니다.
#
# [지원 프로바이더 및 모델명 형식]
#   프로바이더    │ 모델명 예시                          │ 필요한 API 키
#   ─────────────┼──────────────────────────────────────┼──────────────────
#   OpenAI       │ gpt-4o-mini, gpt-4o, gpt-5.2        │ OPENAI_API_KEY
#   Anthropic    │ claude-3-5-sonnet-20241022           │ ANTHROPIC_API_KEY
#   Google       │ gemini/gemini-1.5-flash              │ GEMINI_API_KEY
#   Ollama       │ ollama/llama3, ollama/mistral        │ (불필요, 로컬 실행)
#
# 모델명에 따라 LiteLLM이 자동으로 해당 프로바이더의 API 키를 사용합니다.
# 예) CHATBOT_MODEL=gpt-5.2 → OPENAI_API_KEY 사용
#     INSIGHT_MODEL=claude-3-5-sonnet-20241022 → ANTHROPIC_API_KEY 사용

# ── API 키 (사용하는 프로바이더만 설정) ────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── 글로벌 기본 모델 ──────────────────────────
# 개별 서비스에 모델이 지정되지 않은 경우 이 모델을 사용합니다.
LITELLM_MODEL=gpt-4o-mini

# ── 챗봇 (Deep Agent) ──────────────────────────
# 대화형 재무 상담 AI. 4개 서브에이전트(Researcher, Fetcher, Analyzer, Advisor) 사용.
# 대화 품질이 중요하므로 고성능 모델 권장.
# 미설정 시 LITELLM_MODEL 값 사용
CHATBOT_MODEL=gpt-5.2
CHATBOT_MAX_TOKENS=2048
CHATBOT_TEMPERATURE=0.7
CHATBOT_MAX_HISTORY=20

# ── 뉴스 LLM ──────────────────────────────────
# 뉴스 기사 요약, 감성 분석, 클러스터링에 사용.
# 정확한 JSON 출력이 필요하므로 낮은 temperature 권장.
# 미설정 시 LITELLM_MODEL 값 사용
NEWS_LLM_MODEL=gpt-5-mini
NEWS_LLM_MAX_TOKENS=1024
NEWS_LLM_TEMPERATURE=0.3

# ── AI 인사이트 ────────────────────────────────
# 대시보드 AI 위젯. 자산/예산 데이터 분석 후 인사이트 제공.
# 짧은 응답이므로 경량 모델로도 충분.
# 미설정 시 LITELLM_MODEL 값 사용
INSIGHT_MODEL=gpt-5-mini
INSIGHT_MAX_TOKENS=512
INSIGHT_TEMPERATURE=0.5
